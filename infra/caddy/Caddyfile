# Caddy configuration for the API-only TCRN TMS runtime

# Global options
{
    # Email for Let's Encrypt notifications
    email {$ACME_EMAIL:admin@tcrn.app}
    
    # Enable admin API for dynamic config
    admin off
    
    # Logging
    log {
        output stdout
        format json
        level INFO
    }
}

tcrn.app, www.tcrn.app {
    encode gzip zstd

    handle /api/* {
        reverse_proxy api:4000
    }

    handle {
        respond "Repo-owned web runtime removed" 404
    }

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-XSS-Protection "1; mode=block"
        -Server
    }
}
:80 {
    respond /health "OK" 200
    @notHealth not path /health
    redir @notHealth https://{host}{uri} permanent
}
