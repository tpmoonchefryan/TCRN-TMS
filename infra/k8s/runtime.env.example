# First-cut single-node K3s runtime env example.
#
# This file is intentionally K3s-specific.
# It is not the old Compose production env contract.
#
# Important:
# - FRONTEND_URL / APP_URL / CORS_ORIGIN should point at the external browser runtime or public origin.
# - DATABASE_URL must not point at localhost/127.0.0.1 from inside pods.
#   Use a host IP or DNS name reachable from the K3s network.

# =============================================================================
# Application Environment
# =============================================================================
NODE_ENV=production

# =============================================================================
# Public URLs
# =============================================================================
FRONTEND_URL=https://app.example.com
APP_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://tcrn:replace-me-db-password@replace-me-db-host:5432/tcrn_tms

# =============================================================================
# Redis / MinIO / NATS
# =============================================================================
REDIS_URL=redis://:replace-me-redis-password@tcrn-redis.tcrn.svc.cluster.local:6379
MINIO_ENDPOINT=tcrn-minio.tcrn.svc.cluster.local:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-me-minio-password
MINIO_USE_SSL=false
NATS_URL=nats://tcrn-nats.tcrn.svc.cluster.local:4222

# =============================================================================
# JWT Secrets
# =============================================================================
JWT_SECRET=replace-me-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-me-with-at-least-32-characters
FINGERPRINT_SECRET_KEY=replace-me-fingerprint-secret

# =============================================================================
# Email
# =============================================================================
TENCENT_SES_SECRET_ID=replace-me-tencent-ses-secret-id
TENCENT_SES_SECRET_KEY=replace-me-tencent-ses-secret-key
TENCENT_SES_FROM_ADDRESS=noreply@tcrn-tms.com
EMAIL_CONFIG_ENCRYPTION_KEY=replace-me-64-char-hex-key-for-stored-email-config

# =============================================================================
# Optional Observability
# =============================================================================
LOKI_ENABLED=false
LOKI_PUSH_URL=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
