{
  "name": "@tcrn/api",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run --config ./vitest.config.ts",
    "test:cov": "vitest run --config ./vitest.config.ts --coverage",
    "test:integration": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; if [ \"$#\" -eq 0 ]; then set -- test/integration; fi; vitest run --config ./vitest.integration.config.ts \"$@\"' --",
    "test:isolation": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; if [ \"$#\" -eq 0 ]; then set -- src/testing/isolation; fi; vitest run --config ./vitest.integration.config.ts \"$@\"' --"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.23",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.23",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "11.1.23",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/throttler": "6.5.0",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@prisma/client": "6.14.0",
    "@tcrn/database": "workspace:*",
    "@tcrn/shared": "workspace:*",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "2.1.0",
    "argon2": "0.44.0",
