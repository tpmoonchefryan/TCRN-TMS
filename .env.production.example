# TCRN TMS Production Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=tcrn
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=tcrn_tms

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PASSWORD=your-secure-redis-password

# =============================================================================
# Observability (Optional)
# =============================================================================
LOKI_ENABLED=false
LOKI_PUSH_URL=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set only when a dedicated OTLP metrics collector is available.
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=

# =============================================================================
# MinIO Object Storage
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-secure-minio-password

# =============================================================================
# JWT Secrets (MUST be at least 32 characters)
# Generate with: openssl rand -base64 32
# =============================================================================
JWT_SECRET=your-32-character-jwt-secret-here
JWT_REFRESH_SECRET=your-32-character-refresh-secret
FINGERPRINT_SECRET_KEY=your-fingerprint-secret-key

# =============================================================================
# External PII Platform
# Enable `TCRN_PII_PLATFORM` through tenant/subsidiary/talent integration adapters.
# This repository no longer requires a repo-owned PII runtime URL.
# =============================================================================

# =============================================================================
# Public URLs
# =============================================================================
NEXT_PUBLIC_API_URL=https://web.prod.tcrn-tms.com
NEXT_PUBLIC_APP_URL=https://web.prod.tcrn-tms.com

# =============================================================================
# Caddy / Let's Encrypt
# =============================================================================
ACME_EMAIL=admin@tcrn-tms.com

# =============================================================================
# Email Configuration (Tencent SES)
# =============================================================================
EMAIL_CONFIG_ENCRYPTION_KEY=your-email-config-encryption-key
TENCENT_SES_SECRET_ID=your-tencent-ses-secret-id
TENCENT_SES_SECRET_KEY=your-tencent-ses-secret-key
TENCENT_SES_FROM_ADDRESS=noreply@tcrn-tms.com
